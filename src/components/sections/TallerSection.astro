---
import { site } from '@config/site';

interface Props {
  tallerFoto: string;
  servicios: string[];
}

const { tallerFoto, servicios } = Astro.props;
---

<section id="taller" class="py-16 md:py-20 bg-white" aria-label="Taller y postventa">
  <div class="max-w-5xl mx-auto px-5">
    <h2 class="section-title">Servicio y Postventa</h2>
    <p class="section-subtitle">Taller especializado para mantener tu moto en óptimas condiciones</p>

    <div class="grid md:grid-cols-2 gap-8 md:gap-12 items-center">
      <!-- Foto del taller -->
      <div class="overflow-hidden rounded-2xl shadow-md aspect-[4/3] bg-gray-100">
        <img
          src={tallerFoto}
          alt={`Taller de servicio ${site.nombre}`}
          class="w-full h-full object-cover"
          loading="lazy"
          decoding="async"
        />
      </div>

      <!-- Servicios -->
      <div>
        <h3 class="text-xl font-bold mb-5" style="color: var(--color-secondary)">
          Puntos de servicio
        </h3>
        <ul class="flex flex-col gap-3">
          {servicios.map((servicio) => (
            <li class="flex items-start gap-3">
              <span
                class="flex items-center justify-center w-6 h-6 rounded-full text-white text-xs font-bold shrink-0 mt-0.5"
                style="background-color: var(--color-primary)"
              >
                ✓
              </span>
              <span class="text-gray-700">{servicio}</span>
            </li>
          ))}
        </ul>
      </div>
    </div>
  </div>
</section>

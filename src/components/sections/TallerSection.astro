---
import { waLink } from '@config/site';

interface Props {
  tallerFoto: string;
  servicios: string[];
}

const { } = Astro.props;

const waAgenda = waLink('Hola, quisiera agendar una cita en el taller.');
const waRepuestos = waLink('Hola, quisiera consultar sobre repuestos y accesorios.');

const serviciosTecnicos = [
  'Mantenimiento preventivo',
  'Mantenimiento correctivo',
  'Cambio de aceite y filtros',
  'Revisión y ajuste de frenos',
  'Servicio de garantía oficial',
];

const repuestos = [
  'Repuestos originales disponibles',
  'Accesorios para motos',
  'Filtros, aceites y componentes',
  'Asesoría personalizada',
  'Stock según disponibilidad',
];
---

<section id="taller" class="overflow-hidden" aria-label="Taller y postventa">

  <!-- Fondo oscuro con imagen -->
  <div class="relative py-14 md:py-20 flex items-center justify-center text-center">
    <img
      src="/images/TALLER Y POSTVENTA.jpg"
      alt="Taller Rashag Motos"
      class="absolute inset-0 w-full h-full object-cover"
      loading="lazy"
      decoding="async"
    />
    <div class="absolute inset-0" style="background: rgba(10,10,20,0.72);"></div>

    <div class="relative z-10 px-5">
      <div class="flex items-center justify-center gap-3 mb-3">
        <span class="w-1 h-10 rounded-full" style="background-color: var(--color-primary);"></span>
        <h2 class="text-3xl md:text-5xl font-extrabold text-white uppercase tracking-tight">
          Servicio Postventa
        </h2>
      </div>
      <p class="text-gray-300 text-sm md:text-base max-w-lg mx-auto">
        Soluciones especializadas para mantener tu moto en óptimas condiciones.
      </p>
    </div>
  </div>

  <!-- Tarjetas -->
  <div class="bg-gray-100 py-12 px-5">
    <div class="max-w-5xl mx-auto grid grid-cols-1 md:grid-cols-2 gap-6">

      <!-- Tarjeta 1: Servicio Técnico -->
      <div class="bg-white rounded-2xl shadow-md overflow-hidden flex flex-col">
        <img
          src="/images/TALLER.jpg"
          alt="Servicio técnico Rashag"
          class="w-full h-52 object-cover"
          loading="lazy"
          decoding="async"
        />
        <div class="p-6 flex flex-col flex-1">
          <div class="flex items-center gap-3 mb-3">
            <svg class="w-6 h-6 shrink-0" style="color: var(--color-primary)" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z" />
            </svg>
            <h3 class="text-lg font-extrabold uppercase tracking-wide" style="color: var(--color-secondary)">Servicio Técnico</h3>
          </div>
          <p class="text-gray-600 text-sm mb-4">
            Realizamos mantenimiento preventivo, correctivo y revisiones especializadas para que tu moto se mantenga segura y en óptimo estado.
          </p>
          <ul class="flex flex-col gap-2 mb-6">
            {serviciosTecnicos.map((s) => (
              <li class="flex items-center gap-2 text-sm text-gray-700">
                <span class="w-1.5 h-1.5 rounded-full shrink-0" style="background-color: var(--color-primary);"></span>
                {s}
              </li>
            ))}
          </ul>
          <a
            href={waAgenda}
            target="_blank"
            rel="noopener noreferrer"
            class="mt-auto inline-flex items-center gap-1 text-sm font-bold uppercase tracking-wide hover:underline"
            style="color: var(--color-primary)"
          >
            Agendar cita
            <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" />
            </svg>
          </a>
        </div>
      </div>

      <!-- Tarjeta 2: Venta de Repuestos -->
      <div class="bg-white rounded-2xl shadow-md overflow-hidden flex flex-col">
        <img
          src="/images/REPUESTOS.jpg"
          alt="Repuestos Rashag"
          class="w-full h-52 object-cover object-right"
          loading="lazy"
          decoding="async"
        />
        <div class="p-6 flex flex-col flex-1">
          <div class="flex items-center gap-3 mb-3">
            <svg class="w-6 h-6 shrink-0" style="color: var(--color-primary)" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4" />
            </svg>
            <h3 class="text-lg font-extrabold uppercase tracking-wide" style="color: var(--color-secondary)">Venta de Repuestos</h3>
          </div>
          <p class="text-gray-600 text-sm mb-4">
            Contamos con repuestos y accesorios para motos, brindando atención especializada y productos de calidad.
          </p>
          <ul class="flex flex-col gap-2 mb-6">
            {repuestos.map((r) => (
              <li class="flex items-center gap-2 text-sm text-gray-700">
                <span class="w-1.5 h-1.5 rounded-full shrink-0" style="background-color: var(--color-primary);"></span>
                {r}
              </li>
            ))}
          </ul>
          <a
            href={waRepuestos}
            target="_blank"
            rel="noopener noreferrer"
            class="mt-auto inline-flex items-center gap-1 text-sm font-bold uppercase tracking-wide hover:underline"
            style="color: var(--color-primary)"
          >
            Consultar repuestos
            <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" />
            </svg>
          </a>
        </div>
      </div>

    </div>
  </div>

</section>

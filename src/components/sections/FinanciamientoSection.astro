---
import { waLink } from '@config/site';

interface Props {
  desde: string;
  notas: string[];
}

const { } = Astro.props;

const waHref = waLink('Hola, quisiera información sobre las opciones de crédito para una moto.');
---

<section id="financiamiento" class="relative w-full aspect-[6/7] md:aspect-auto md:min-h-[500px] flex items-end md:items-center overflow-hidden" aria-label="Financiamiento">

  <!-- Imagen de fondo desktop -->
  <img
    src="/images/R1-CREDITO.jpg"
    alt="Crédito para tu moto en Rashag Motos"
    class="absolute inset-0 w-full h-full object-cover hidden md:block"
    loading="lazy"
    decoding="async"
  />
  <!-- Imagen de fondo móvil (con texto incluido) -->
  <img
    src="/images/CREDITO MOTOS.jpg"
    alt="Crédito para tu moto en Rashag Motos"
    class="absolute inset-0 w-full h-full object-cover block md:hidden"
    loading="lazy"
    decoding="async"
  />

  <!-- Overlay oscuro (solo desktop) -->
  <div class="absolute inset-0 hidden md:block" style="background: linear-gradient(135deg, rgba(0,0,0,0.55) 0%, rgba(0,0,0,0.2) 100%);"></div>

  <!-- Botón solo móvil -->
  <a
    href={waHref}
    target="_blank"
    rel="noopener noreferrer"
    class="md:hidden relative z-10 mb-4 ml-6 inline-flex items-center gap-2 px-6 py-3 font-bold text-sm uppercase tracking-widest text-white border-2 border-white rounded-lg"
  >
    Solicitar Crédito
  </a>

  <!-- Contenido (solo desktop) -->
  <div class="relative z-10 hidden md:block pl-6 md:pl-10 lg:pl-16 pr-6 md:pr-10 py-8 md:py-20">

    <!-- Label -->
    <p class="text-xs font-bold uppercase tracking-widest mb-4" style="color: var(--color-primary)">
      Crédito
    </p>

    <!-- Título -->
    <h2 class="text-2xl md:text-5xl lg:text-6xl font-extrabold text-white uppercase leading-tight mb-5 max-w-3xl">
      Tenemos el crédito<br />que buscas para<br />tu moto
    </h2>

    <!-- Subtítulo -->
    <p class="text-gray-300 text-sm md:text-base mb-8 max-w-md">
      Solicita tu crédito de forma rápida, segura y 100% online.
    </p>

    <!-- CTA -->
    <a
      href={waHref}
      target="_blank"
      rel="noopener noreferrer"
      class="inline-flex items-center gap-2 px-8 py-4 font-bold text-sm uppercase tracking-widest text-white border-2 border-white rounded-lg hover:bg-white hover:text-black transition-colors duration-200"
    >
      Solicitar Crédito
    </a>
  </div>

</section>

---
import { site, waLink } from '@config/site';

interface Props {
  direccion: string;
  horario: string;
}

const { direccion, horario } = Astro.props;

const waHref = waLink('Hola, me comunico desde su sitio web. Quisiera más información.');
---

<section
  id="contacto"
  class="py-16 md:py-20"
  style="background-color: var(--color-secondary);"
  aria-label="Canales oficiales de contacto"
>
  <div class="max-w-4xl mx-auto px-5">
    <h2 class="text-2xl md:text-3xl font-bold text-center text-white mb-2">
      Canales Oficiales
    </h2>
    <p class="text-center text-gray-400 mb-10 text-sm md:text-base">
      Comunícate únicamente a través de estos canales verificados
    </p>

    <!-- Grid de canales -->
    <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 mb-8">
      <!-- WhatsApp -->
      <a
        href={waHref}
        target="_blank"
        rel="noopener noreferrer"
        class="flex items-center gap-4 bg-white/10 hover:bg-white/15 transition-colors rounded-xl p-5 border border-white/10"
      >
        <span class="flex items-center justify-center w-12 h-12 rounded-full bg-[#25D366] text-white text-2xl shrink-0">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="white" class="w-6 h-6">
            <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347z"/>
            <path d="M12 0C5.373 0 0 5.373 0 12c0 2.127.558 4.122 1.532 5.857L.054 23.389a.75.75 0 0 0 .906.981l5.747-1.507A11.944 11.944 0 0 0 12 24c6.627 0 12-5.373 12-12S18.627 0 12 0zm0 22c-1.9 0-3.677-.514-5.2-1.408l-.373-.22-3.865 1.013 1.032-3.76-.242-.387A9.96 9.96 0 0 1 2 12C2 6.477 6.477 2 12 2s10 4.477 10 10-4.477 10-10 10z"/>
          </svg>
        </span>
        <div>
          <p class="text-xs text-gray-400 font-medium uppercase tracking-wide">WhatsApp oficial</p>
          <p class="text-white font-bold text-lg">{site.whatsapp_display}</p>
        </div>
      </a>

      <!-- Dirección -->
      <a
        href={site.google_maps_url}
        target="_blank"
        rel="noopener noreferrer"
        class="flex items-center gap-4 bg-white/10 hover:bg-white/15 transition-colors rounded-xl p-5 border border-white/10"
      >
        <span class="flex items-center justify-center w-12 h-12 rounded-full shrink-0" style="background-color: var(--color-primary)">
          <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
            <path stroke-linecap="round" stroke-linejoin="round" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
          </svg>
        </span>
        <div>
          <p class="text-xs text-gray-400 font-medium uppercase tracking-wide">Dirección</p>
          <p class="text-white font-semibold text-sm leading-snug">{direccion}</p>
        </div>
      </a>

      <!-- Facebook -->
      <a
        href={site.facebook_url}
        target="_blank"
        rel="noopener noreferrer"
        class="flex items-center gap-4 bg-white/10 hover:bg-white/15 transition-colors rounded-xl p-5 border border-white/10"
      >
        <span class="flex items-center justify-center w-12 h-12 rounded-full bg-[#1877F2] shrink-0">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="white" class="w-6 h-6">
            <path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/>
          </svg>
        </span>
        <div>
          <p class="text-xs text-gray-400 font-medium uppercase tracking-wide">Facebook oficial</p>
          <p class="text-white font-semibold text-sm">{site.facebook_url.replace('https://', '')}</p>
        </div>
      </a>

      <!-- Instagram -->
      <a
        href={site.instagram_url}
        target="_blank"
        rel="noopener noreferrer"
        class="flex items-center gap-4 bg-white/10 hover:bg-white/15 transition-colors rounded-xl p-5 border border-white/10"
      >
        <span class="flex items-center justify-center w-12 h-12 rounded-full shrink-0" style="background: linear-gradient(45deg, #f09433 0%, #e6683c 25%, #dc2743 50%, #cc2366 75%, #bc1888 100%);">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="white" class="w-6 h-6">
            <path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 1 0 0 12.324 6.162 6.162 0 0 0 0-12.324zM12 16a4 4 0 1 1 0-8 4 4 0 0 1 0 8zm6.406-11.845a1.44 1.44 0 1 0 0 2.881 1.44 1.44 0 0 0 0-2.881z"/>
          </svg>
        </span>
        <div>
          <p class="text-xs text-gray-400 font-medium uppercase tracking-wide">Instagram oficial</p>
          <p class="text-white font-semibold text-sm">{site.instagram_url.replace('https://', '')}</p>
        </div>
      </a>

      <!-- TikTok -->
      <a
        href={site.tiktok_url}
        target="_blank"
        rel="noopener noreferrer"
        class="flex items-center gap-4 bg-white/10 hover:bg-white/15 transition-colors rounded-xl p-5 border border-white/10"
      >
        <span class="flex items-center justify-center w-12 h-12 rounded-full bg-black shrink-0">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="white" class="w-6 h-6">
            <path d="M19.59 6.69a4.83 4.83 0 0 1-3.77-4.25V2h-3.45v13.67a2.89 2.89 0 0 1-2.88 2.5 2.89 2.89 0 0 1-2.89-2.89 2.89 2.89 0 0 1 2.89-2.89c.28 0 .54.04.79.1V9.01a6.33 6.33 0 0 0-.79-.05 6.34 6.34 0 0 0-6.34 6.34 6.34 6.34 0 0 0 6.34 6.34 6.34 6.34 0 0 0 6.33-6.34V8.69a8.18 8.18 0 0 0 4.78 1.52V6.75a4.85 4.85 0 0 1-1.01-.06z"/>
          </svg>
        </span>
        <div>
          <p class="text-xs text-gray-400 font-medium uppercase tracking-wide">TikTok oficial</p>
          <p class="text-white font-semibold text-sm">{site.tiktok_url.replace('https://', '')}</p>
        </div>
      </a>

      <!-- Empresa -->
      <div class="flex items-center gap-4 bg-white/10 rounded-xl p-5 border border-white/10">
        <div>
          <p class="text-xs text-gray-400 font-medium uppercase tracking-wide mb-1">Empresa</p>
          <p class="text-white font-semibold">{site.razon_social}</p>
          <p class="text-gray-300 text-sm">RUC: {site.ruc}</p>
        </div>
      </div>
    </div>

    <!-- Aviso antiestafa — hardcoded, no editable -->
    <div class="flex items-start gap-3 bg-red-900/60 border border-red-700 rounded-xl p-5">
      <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6 text-red-400 shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z" />
      </svg>
      <p class="text-red-200 text-sm font-medium leading-relaxed">
        <strong class="text-red-100 block mb-2">Aviso de seguridad</strong>
        Los únicos canales oficiales de atención, venta y comunicación son los publicados en este sitio web. Esto incluye números de WhatsApp, teléfonos, redes sociales, direcciones y demás medios de contacto aquí mostrados.
        <br /><br />
        No realizamos cobros desde cuentas personales ni nos hacemos responsables por depósitos, transferencias o acuerdos realizados a través de números, perfiles o cuentas no publicados en esta web oficial.
        <br /><br />
        Antes de realizar cualquier pago o separación, verifique siempre que está contactando con nuestros canales oficiales.
      </p>
    </div>
  </div>
</section>

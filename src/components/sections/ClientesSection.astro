---
interface Props {
  clientes: { foto: string; modelo_moto?: string; ciudad?: string }[];
}

const { clientes } = Astro.props;

const items = [...clientes, ...clientes];
---

<section id="clientes" class="py-14 md:py-16 bg-white overflow-hidden" aria-label="Comunidad Rashag">

  <!-- Encabezado con flechas navegables -->
  <div class="max-w-6xl mx-auto px-5 mb-8 flex items-center justify-center gap-6">
    <button id="btn-prev" aria-label="Anterior" class="w-8 h-8 flex items-center justify-center text-gray-500 hover:text-gray-900 transition-colors text-2xl font-light leading-none">‹</button>
    <h2 class="text-lg md:text-xl font-bold text-gray-800 tracking-wide">Comunidad Rashag</h2>
    <button id="btn-next" aria-label="Siguiente" class="w-8 h-8 flex items-center justify-center text-gray-500 hover:text-gray-900 transition-colors text-2xl font-light leading-none">›</button>
  </div>

  <!-- Carrusel -->
  <div class="carousel-track-wrapper">
    <div id="carousel-track" class="carousel-track">
      {items.map((c) => (
        <div class="carousel-card">
          <img
            src={c.foto}
            alt={c.modelo_moto ? `Cliente con ${c.modelo_moto}` : 'Cliente Rashag Motos'}
            class="w-full h-full object-cover"
            loading="lazy"
            decoding="async"
          />
          {(c.modelo_moto || c.ciudad) && (
            <div class="carousel-overlay">
              {c.modelo_moto && <span class="font-semibold text-white text-sm leading-tight">{c.modelo_moto}</span>}
              {c.ciudad && <span class="text-gray-300 text-xs">{c.ciudad}</span>}
            </div>
          )}
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .carousel-track-wrapper {
    width: 100%;
    overflow: hidden;
    mask-image: linear-gradient(to right, transparent 0%, black 8%, black 92%, transparent 100%);
    -webkit-mask-image: linear-gradient(to right, transparent 0%, black 8%, black 92%, transparent 100%);
  }

  .carousel-track {
    display: flex;
    gap: 16px;
    width: max-content;
    animation: slide 30s linear infinite;
    transition: transform 0.4s ease;
  }

  .carousel-track:hover,
  .carousel-track.paused {
    animation-play-state: paused;
  }

  .carousel-card {
    position: relative;
    width: 260px;
    height: 260px;
    border-radius: 12px;
    overflow: hidden;
    flex-shrink: 0;
    background: #1a1a2e;
  }

  .carousel-overlay {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    padding: 10px 12px;
    background: linear-gradient(to top, rgba(0,0,0,0.75) 0%, transparent 100%);
    display: flex;
    flex-direction: column;
    gap: 1px;
  }

  @keyframes slide {
    0%   { transform: translateX(0); }
    100% { transform: translateX(calc(-50% - 8px)); }
  }

  @media (prefers-reduced-motion: reduce) {
    .carousel-track {
      animation: none;
      flex-wrap: wrap;
      justify-content: center;
      width: 100%;
    }
  }
</style>

<script>
  const track = document.getElementById('carousel-track')!;
  const btnPrev = document.getElementById('btn-prev')!;
  const btnNext = document.getElementById('btn-next')!;
  const cardWidth = 260 + 16; // ancho + gap

  function pause() {
    track.classList.add('paused');
    clearTimeout((window as any)._carouselResume);
    (window as any)._carouselResume = setTimeout(() => track.classList.remove('paused'), 3000);
  }

  btnNext.addEventListener('click', () => {
    pause();
    const current = new DOMMatrix(getComputedStyle(track).transform).m41;
    track.style.animation = 'none';
    track.style.transform = `translateX(${current - cardWidth}px)`;
    setTimeout(() => { track.style.animation = ''; track.style.transform = ''; }, 400);
  });

  btnPrev.addEventListener('click', () => {
    pause();
    const current = new DOMMatrix(getComputedStyle(track).transform).m41;
    track.style.animation = 'none';
    track.style.transform = `translateX(${current + cardWidth}px)`;
    setTimeout(() => { track.style.animation = ''; track.style.transform = ''; }, 400);
  });
</script>

---
import Lightbox from '@components/ui/Lightbox.astro';

interface Props {
  fotos: { foto: string; alt?: string }[];
}

const { fotos } = Astro.props;
---

<section id="galeria" class="py-16 md:py-20 bg-gray-50" aria-label="Galería del local">
  <div class="max-w-5xl mx-auto px-5">
    <h2 class="section-title">Conoce Nuestra Tienda</h2>
    <p class="section-subtitle">Visítanos y conoce nuestra sala de ventas y taller</p>

    <Lightbox images={fotos} />
  </div>
</section>

---
interface Props {
  marcas: { nombre: string; logo: string }[];
}

const { marcas } = Astro.props;
---

<section id="marcas" class="py-14 md:py-16 bg-white border-y border-gray-100" aria-label="Marcas que representamos">
  <div class="max-w-6xl mx-auto px-5">
    <p class="text-xs font-semibold uppercase tracking-widest text-center mb-8" style="color: var(--color-primary)">
      Marcas que representamos
    </p>

    <!-- Banda horizontal: scroll en móvil, flex centrado en desktop -->
    <div class="flex items-center gap-0 overflow-x-auto md:overflow-visible md:justify-center scrollbar-hide">
      {marcas.map((marca, i) => (
        <>
          <div class="flex flex-col items-center justify-center gap-3 px-8 md:px-10 py-2 shrink-0 group">
            <img
              src={marca.logo}
              alt={`Logo ${marca.nombre}`}
              class="h-6 md:h-8 w-auto object-contain opacity-60 group-hover:opacity-100 transition-opacity duration-200 grayscale group-hover:grayscale-0"
              loading="lazy"
              decoding="async"
            />
          </div>

          {/* Divisor vertical entre marcas, excepto después del último */}
          {i < marcas.length - 1 && (
            <div class="h-10 w-px bg-gray-200 shrink-0" aria-hidden="true" />
          )}
        </>
      ))}
    </div>
  </div>
</section>

<style>
  .scrollbar-hide {
    -ms-overflow-style: none;
    scrollbar-width: none;
  }
  .scrollbar-hide::-webkit-scrollbar {
    display: none;
  }
</style>

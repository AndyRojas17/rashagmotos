---
import { site } from '@config/site';
import '../styles/global.css';
import WhatsAppFloat from '@components/ui/WhatsAppFloat.astro';
import NavBar from '@components/ui/NavBar.astro';
import PopupAviso from '@components/ui/PopupAviso.astro';

interface Props {
  title?: string;
  description?: string;
  ogImage?: string;
}

const {
  title = site.nombre,
  description = site.meta.description,
  ogImage = site.meta.og_image,
} = Astro.props;

const fullTitle = title === site.nombre ? title : `${title} — ${site.nombre}`;
---

<!doctype html>
<html lang={site.meta.lang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="robots" content="index, follow" />

    <!-- Open Graph -->
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:type" content="website" />

    <!-- Favicon placeholder -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <!-- Inter font -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap"
      rel="stylesheet"
    />

    <title>{fullTitle}</title>

    <!-- Inyectar variables de color de marca como CSS custom properties -->
    <style define:vars={{ colorPrimary: site.colors.primary, colorSecondary: site.colors.secondary }}>
      :root {
        --color-primary: var(--colorPrimary);
        --color-secondary: var(--colorSecondary);
      }
    </style>
  </head>
  <body id="top">
    <NavBar />
    <slot />
    <WhatsAppFloat />
    <PopupAviso />
  </body>
</html>
